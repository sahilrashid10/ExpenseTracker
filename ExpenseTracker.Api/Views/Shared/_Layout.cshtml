<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Expense Tracker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function () {
            const storedTheme = localStorage.getItem('expense-theme');
            const preferredTheme = storedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', preferredTheme);
        })();
    </script>
</head>
<body>
    <header class="topbar">
        <div class="container d-flex align-items-center justify-content-between py-3">
            <div>
                <div class="brand-kicker">FinEdge Corp</div>
                <h1 class="brand-title">Expense Tracker</h1>
            </div>
            <div class="topbar-actions">
                <nav class="desktop-nav d-flex align-items-center gap-3 flex-wrap justify-content-end">
                    <a class="nav-linkx" href="/">Dashboard</a>
                    <a class="nav-linkx" href="/expenses/create">Add Expense</a>
                    <a class="nav-linkx" href="/expenses">API</a>
                    <a class="nav-linkx" href="/expenses/summary">Summary</a>
                </nav>
                <button class="theme-toggle" type="button" id="themeToggle" aria-label="Toggle light and dark mode">
                    <span class="theme-toggle__label theme-toggle__label--light">Light</span>
                    <span class="theme-toggle__knob"></span>
                    <span class="theme-toggle__label theme-toggle__label--dark">Dark</span>
                </button>
                <button class="menu-toggle" type="button" id="menuToggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobileNav">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>
        <nav id="mobileNav" class="mobile-nav container" aria-hidden="true">
            <a class="nav-linkx" href="/">Dashboard</a>
            <a class="nav-linkx" href="/expenses/create">Add Expense</a>
            <a class="nav-linkx" href="/expenses">API</a>
            <a class="nav-linkx" href="/expenses/summary">Summary</a>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const button = document.getElementById('themeToggle');
            const root = document.documentElement;

            if (!button) {
                return;
            }

            const syncButton = () => {
                const theme = root.getAttribute('data-theme') || 'light';
                button.setAttribute('data-active-theme', theme);
            };

            button.addEventListener('click', function () {
                const nextTheme = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                root.setAttribute('data-theme', nextTheme);
                localStorage.setItem('expense-theme', nextTheme);
                syncButton();
            });

            syncButton();
        })();

        (function () {
            const toggle = document.getElementById('menuToggle');
            const mobileNav = document.getElementById('mobileNav');

            if (!toggle || !mobileNav) {
                return;
            }

            toggle.addEventListener('click', function () {
                const isOpen = mobileNav.classList.toggle('is-open');
                toggle.setAttribute('aria-expanded', String(isOpen));
                mobileNav.setAttribute('aria-hidden', String(!isOpen));
            });
        })();
    </script>
</body>
</html>